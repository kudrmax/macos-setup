[credential]
	helper = osxkeychain
[user]
	name = Maksim Kudryashov
	email = mdmkudryashov@avito.ru
[alias]
	st = status
	ch = checkout
	br = branch
	dog = log --oneline --graph
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[init]
	defaultBranch = master
